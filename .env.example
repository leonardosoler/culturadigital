# ===========================================
# Configuração de ambiente - CulturaDigital
# Copie este arquivo para ".env" e ajuste os valores
# ===========================================

# Django
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Banco de dados (Postgres)
POSTGRES_DB=culturadigital
POSTGRES_USER=culturadigital
POSTGRES_PASSWORD=culturadigital
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# IA (Anthropic Claude) - necessário para resumo de editais, checklist e minutas
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# CORS / Frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000/api
